# =========================
# Local runtime (Python direct run)
# =========================
APP_HOST=127.0.0.1
APP_PORT=8091

# Use local writable paths (do NOT use /app/* locally)
APP_DATA_DIR=/Users/sy/my-todo/data
APP_RUNTIME_DIR=/Users/sy/my-todo/runtime

# =========================
# Emby defaults (optional)
# =========================
APP_EMBY_SERVER_URL=
APP_EMBY_API_KEY=
APP_EMBY_CLIENT_NAME="镜界Vistamirror User Console"

# =========================
# Telegram defaults (optional)
# =========================
APP_BOT_TELEGRAM_TOKEN=
APP_BOT_TELEGRAM_CHAT_ID=

# =========================
# Bot/Webhook advanced
# =========================
BOT_WEBHOOK_TOKEN=vistamirror
BOT_PUBLIC_BASE_URL=
TG_PROXY_URL=
EMBY_PUBLIC_WEB_URL=

# =========================
# Admin auth (required if enabled)
# =========================
APP_ADMIN_AUTH_ENABLED=1
APP_ADMIN_USERNAME=admin
# 若设置了 APP_ADMIN_USERNAME + APP_ADMIN_PASSWORD_HASH，则后台凭据由环境变量接管（设置页不可修改）
# 若留空这两个字段，则可在“系统设置 -> 后台管理员凭据”里修改（会写入 data/admin_auth.json）
APP_ADMIN_PASSWORD_HASH=
APP_ADMIN_SESSION_TTL_SECONDS=86400
APP_ADMIN_LOGIN_MAX_FAILS=5
APP_ADMIN_LOGIN_LOCK_SECONDS=900
