# =========================
# App runtime
# =========================
# Docker 专用示例（本地直跑请用 .env.local）
# Docker image (for deploy/rollback)
IMAGE_NAME=fancha0/vistamirror-admin:latest

APP_HOST=0.0.0.0
APP_PORT=8091

# Inside container paths (usually keep default)
APP_DATA_DIR=/app/data
APP_RUNTIME_DIR=/app/runtime

# =========================
# Emby defaults (env-priority)
# =========================
# Example: https://emby.example.com/emby
APP_EMBY_SERVER_URL=
APP_EMBY_API_KEY=
APP_EMBY_CLIENT_NAME=镜界Vistamirror User Console

# =========================
# Telegram defaults (env-priority)
# =========================
APP_BOT_TELEGRAM_TOKEN=
APP_BOT_TELEGRAM_CHAT_ID=

# =========================
# Bot/Webhook advanced
# =========================
BOT_WEBHOOK_TOKEN=vistamirror
# Example: https://cms.example.com
BOT_PUBLIC_BASE_URL=
# Example: http://127.0.0.1:7890
TG_PROXY_URL=
# Example: https://emby.example.com/web
EMBY_PUBLIC_WEB_URL=

# =========================
# Admin auth (recommended enabled)
# =========================
APP_ADMIN_AUTH_ENABLED=1
APP_ADMIN_USERNAME=admin
# 先用 README 里的命令生成 PBKDF2 哈希后再填入
# 若设置了 APP_ADMIN_USERNAME + APP_ADMIN_PASSWORD_HASH，则后台凭据由环境变量接管（设置页不可修改）
# 若留空这两个字段，则可在“系统设置 -> 后台管理员凭据”里修改（会写入 /app/data/admin_auth.json）
APP_ADMIN_PASSWORD_HASH=
APP_ADMIN_SESSION_TTL_SECONDS=86400
APP_ADMIN_LOGIN_MAX_FAILS=5
APP_ADMIN_LOGIN_LOCK_SECONDS=900
