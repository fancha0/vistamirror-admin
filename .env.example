# =========================
# App runtime
# =========================
APP_HOST=0.0.0.0
APP_PORT=8091

# Inside container paths (usually keep default)
APP_DATA_DIR=/app/data
APP_RUNTIME_DIR=/app/runtime

# =========================
# Emby defaults (env-priority)
# =========================
# Example: https://emby.example.com/emby
APP_EMBY_SERVER_URL=
APP_EMBY_API_KEY=
APP_EMBY_CLIENT_NAME=镜界Vistamirror User Console

# =========================
# Telegram defaults (env-priority)
# =========================
APP_BOT_TELEGRAM_TOKEN=
APP_BOT_TELEGRAM_CHAT_ID=

# =========================
# Bot/Webhook advanced
# =========================
BOT_WEBHOOK_TOKEN=vistamirror
# Example: https://cms.example.com
BOT_PUBLIC_BASE_URL=
# Example: http://127.0.0.1:7890
TG_PROXY_URL=
# Example: https://emby.example.com/web
EMBY_PUBLIC_WEB_URL=
